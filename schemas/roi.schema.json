{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "_schema_version": {
      "type": "integer"
    },
    "product": {
      "type": "string",
      "const": "roi"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "domain": {
      "type": "string"
    },
    "timestamp": {
      "type": "string"
    }
  },
  "required": [
    "_schema_version",
    "product",
    "name",
    "description"
  ]
}
