# direnv: load the guardrails-governed Nix devShell on entry (toolbelt + Rust/Python
# toolchain) and auto-install the prek commit/push hooks. Run `direnv allow` once.
#
# Every subagent that cd's in inherits the same env from the shared /nix/store (hot cache)
# and the shared sccache compile cache — no per-shell rebuild.
use flake

# uv-managed Python deps (uv.lock) — sync into .venv and activate. direnv re-runs this only
# when the lockfile/manifest changes (watch_file), so it's a no-op on a warm tree.
watch_file uv.lock pyproject.toml
if has uv && [ -f uv.lock ]; then
  uv sync --frozen >/dev/null 2>&1 || true
fi
[ -f .venv/bin/activate ] && source .venv/bin/activate
